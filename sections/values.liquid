{%- comment -%}
  Pillars of Craftsmanship Values Section
{%- endcomment -%}

<section class="why-choose-us-section" id="values" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-title-wrap reveal-fade-up">
      <span class="section-subtitle">{{ section.settings.subtitle }}</span>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="editorial-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'pillar' -%}
          {%- assign delay_factor = forloop.index0 | times: 0.15 -%}
          <div class="editorial-card reveal-scale" style="transition-delay: {{ delay_factor }}s;" {{ block.shopify_attributes }}>
            <div class="editorial-icon-wrap">
              {%- case block.settings.icon -%}
                {%- when 'needle' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5c-3 0-5.5 2-6.5 5C4.5 13 5.5 16 8 17.5c2 1.2 4.5.8 6-.8 1.5 1.6 4 .8 6-.8 2.5-1.5 3.5-4.5 2.5-7.5-1-3-3.5-5-6.5-5z" />
                    <path d="M12 5v14" />
                    <path d="M6 10c1.5 1.5 3 2 6 2s4.5-.5 6-2" />
                  </svg>
                {%- when 'butterfly' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5l6.74-6.76z" />
                    <path d="M16 8L2 22" />
                    <path d="M17.5 15H9" />
                  </svg>
                {%- when 'silk' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 6c4 0 6 3 8 3s4-3 8-3M4 14c4 0 6 3 8 3s4-3 8-3M4 6v8c0 4 3 6 8 6s8-2 8-6V6" />
                    <path d="M12 9v11" />
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <line x1="9" y1="3" x2="9" y2="21"/>
                  </svg>
              {%- endcase -%}
            </div>
            {%- if block.settings.stat != blank -%}
              <div class="editorial-stat-wrap">
                <span class="editorial-stat-num">{{ block.settings.stat }}</span>
              </div>
            {%- endif -%}
            <h3 class="editorial-card-title">{{ block.settings.title }}</h3>
            <p class="editorial-card-text">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Atelier Value Pillars",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading Text",
      "default": "The Art of Intimate Perfection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle Description",
      "default": "Premium Craftsmanship"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Luxury Vector Icon",
          "options": [
            {
              "value": "needle",
              "label": "Needle & Thread"
            },
            {
              "value": "butterfly",
              "label": "Atelier Dragonfly"
            },
            {
              "value": "silk",
              "label": "Silk Fabric Flow"
            },
            {
              "value": "measure",
              "label": "Couture Tailor Measure"
            }
          ],
          "default": "needle"
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Pillar Stat/Callout (e.g. 100%, 2.5x)",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Pillar Title",
          "default": "Handcrafted Silk Patterns"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Pillar Description",
          "default": "Stitched by master artisans using premium 100% natural Mulberry silk filaments to lay flat against skin."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Atelier Value Pillars",
      "category": "Text",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "icon": "needle",
            "stat": "100%",
            "title": "Wire-Free Support",
            "description": "3D contour-molding lifts and sculpts with <strong>0% underwires</strong>, reducing shoulder pressure by <strong>up to 45%</strong> for weightless all-day support."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "butterfly",
            "stat": "2.5x",
            "title": "Softer Than Silk",
            "description": "Certified organic modal is <strong>50% more breathable</strong> than cotton — wicking moisture in under <strong>2 seconds</strong>, so your skin stays cool and fresh <strong>24/7</strong>."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "silk",
            "stat": "0%",
            "title": "Visible Lines Guarantee",
            "description": "Laser-cut edges lie <strong>100% flat</strong> under any outfit, while <strong>anti-roll micro-waistbands</strong> stretch <strong>4 ways</strong> — zero pinching, zero riding."
          }
        }
      ]
    }
  ]
}
{% endschema %}
