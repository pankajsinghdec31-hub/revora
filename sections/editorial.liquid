{%- comment -%}
  Lifestyle Gallery / Editorial Spotlight Section
{%- endcomment -%}

<section class="gallery-section" id="editorial" data-section-id="{{ section.id }}">
  <div class="gallery-editorial-wrap">
    <!-- Left: Text Panel -->
    <div class="gallery-text-panel reveal-blur">
      <span class="section-subtitle">{{ section.settings.subtitle }}</span>
      <h2 class="gallery-heading">{{ section.settings.title }}</h2>
      <p class="gallery-text">{{ section.settings.content }}</p>
      
      {%- if section.settings.cta_label != blank -%}
        <div>
          <a href="{{ section.settings.cta_link | default: '#best-sellers' }}" class="btn btn-outline-white">
            <span>{{ section.settings.cta_label }}</span>
          </a>
        </div>
      {%- endif -%}
    </div>
    
    <!-- Right: Background Lifestyle Image -->
    <div class="gallery-image-panel reveal-fade-up">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1400 }}" 
             class="gallery-img-bg" 
             alt="{{ section.settings.title | strip_html }}">
      {%- else -%}
        <!-- Fallback styled background -->
        <div style="background: linear-gradient(135deg, var(--espresso-dark), var(--caramel)); width: 100%; height: 100%; min-height: 400px; opacity: 0.85;"></div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial Spotlight",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle Tagline",
      "default": "Revora Philosophy"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading Title",
      "default": "Luxury is <span>Invisible.</span>"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Description Content",
      "default": "We believe that the finest garments are the ones you forget you are wearing. True luxury is an intimate confidence, a silent standard of high-end details that elevate your every day."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Read the Manifesto"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Spotlight Background Image"
    }
  ],
  "presets": [
    {
      "name": "Editorial Spotlight",
      "category": "Image"
    }
  ]
}
{% endschema %}
