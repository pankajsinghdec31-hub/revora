{%- comment -%}
  Brand Storytelling Section
{%- endcomment -%}

<section class="section-padding brand-story-section" id="brand-story" data-section-id="{{ section.id }}">
  <div class="container brand-story-container">
    <div class="brand-story-grid">
      <!-- Left Column: Overlapping Images Collage -->
      <div class="brand-story-images-column">
        <div class="primary-image-wrap">
          {%- if section.settings.image_primary != blank -%}
            <img src="{{ section.settings.image_primary | image_url: width: 800 }}" 
                 alt="{{ section.settings.title | strip_html }}" 
                 class="story-img-primary">
          {%- else -%}
            <div style="background-color: var(--caramel); opacity: 0.15; height: 500px; width: 100%;"></div>
          {%- endif -%}
        </div>
        <div class="secondary-image-wrap">
          {%- if section.settings.image_secondary != blank -%}
            <img src="{{ section.settings.image_secondary | image_url: width: 600 }}" 
                 alt="{{ section.settings.title | strip_html }}" 
                 class="story-img-secondary">
          {%- else -%}
            <div style="background-color: var(--caramel); opacity: 0.25; height: 350px; width: 100%;"></div>
          {%- endif -%}
        </div>
      </div>

      <!-- Right Column: Narrative Content -->
      <div class="brand-story-content-column">
        <span class="section-subtitle">{{ section.settings.subtitle }}</span>
        <h2 class="section-title">{{ section.settings.title }}</h2>

        <div class="brand-story-text-wrap">
          {%- if section.settings.quote != blank -%}
            <p class="brand-story-quote">
              "{{ section.settings.quote }}"
            </p>
          {%- endif -%}
          {%- if section.settings.body1 != blank -%}
            <p class="brand-story-body">
              {{ section.settings.body1 }}
            </p>
          {%- endif -%}
          {%- if section.settings.body2 != blank -%}
            <p class="brand-story-body">
              {{ section.settings.body2 }}
            </p>
          {%- endif -%}
        </div>

        {%- if section.settings.signature != blank -%}
          <div class="brand-story-signature">
            <span class="signature-name">{{ section.settings.signature }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Storytelling",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Heritage Subtitle",
      "default": "Wear Nothing But Yourself"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Story Title",
      "default": "The Revora Vision"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote Narrative",
      "default": "We set out to strip away the noise. Underwear should not be a flashy billboard; it should be a quiet sanctuary of touch."
    },
    {
      "type": "textarea",
      "id": "body1",
      "label": "Story Paragraph 1",
      "default": "By choosing organic beechwood modal fibers and eliminating irritating hardware or tight seams, we created garments that adapt seamlessly to your body. We don't frame you — we set you free."
    },
    {
      "type": "textarea",
      "id": "body2",
      "label": "Story Paragraph 2",
      "default": "Every piece is tailored with invisible micro-stitches and soft luxury elasticity that moves with you, bringing weightless comfort to the center of your daily ritual."
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Atelier Author Signature",
      "default": "Aditya Tayal"
    },
    {
      "type": "image_picker",
      "id": "image_primary",
      "label": "Primary Large Image"
    },
    {
      "type": "image_picker",
      "id": "image_secondary",
      "label": "Secondary Overlap Image"
    }
  ],
  "presets": [
    {
      "name": "Brand Storytelling",
      "category": "Text"
    }
  ]
}
{% endschema %}
