<footer class="footer" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand-col">
        <div class="footer-logo">
          <svg class="footer-logo-icon" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="45" stroke="var(--caramel)" stroke-width="1.5" fill="none"/>
            <line x1="50" y1="30" x2="50" y2="70" stroke="var(--caramel)" stroke-width="1.5"/>
            <circle cx="50" cy="27" r="2.5" fill="var(--caramel)"/>
            <ellipse cx="37" cy="38" rx="14" ry="5" transform="rotate(-10 37 38)" stroke="var(--caramel)" stroke-width="1.5"/>
            <ellipse cx="63" cy="38" rx="14" ry="5" transform="rotate(10 63 38)" stroke="var(--caramel)" stroke-width="1.5"/>
            <ellipse cx="38" cy="48" rx="11" ry="4" transform="rotate(5 38 48)" stroke="var(--caramel)" stroke-width="1.5"/>
            <ellipse cx="62" cy="48" rx="11" ry="4" transform="rotate(-5 62 48)" stroke="var(--caramel)" stroke-width="1.5"/>
            <circle cx="50" cy="42" r="1.5" fill="var(--caramel)"/>
            <circle cx="50" cy="54" r="1.3" fill="var(--caramel)"/>
            <circle cx="50" cy="72" r="1" fill="var(--caramel)"/>
          </svg>
          <span class="footer-logo-text">{{ shop.name }}</span>
        </div>
        <p class="footer-brand-desc">{{ section.settings.about_text }}</p>
        
        <!-- Social Icons -->
        <div class="footer-socials">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="social-icon-btn" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" class="social-icon-btn" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Customizable Links Columns -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-links-col" {{ block.shopify_attributes }}>
            <h4 class="footer-col-title">{{ block.settings.heading }}</h4>
            <ul class="footer-links-list">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}" class="footer-link">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Bottom Copyright -->
    <div class="footer-bottom">
      <p class="copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Luxury Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "Atelier Description",
      "default": "Revora redefines intimate apparel through the lens of luxury, combining premium Italian silks with state-of-the-art flat-lock stitching patterns for second-skin comfort."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "All Rights Reserved."
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Title",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Footer Menu Selector"
        }
      ]
    }
  ]
}
{% endschema %}
