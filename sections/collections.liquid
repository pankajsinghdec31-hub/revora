{%- comment -%}
Curated Collections List Section
{%- endcomment -%}

<section class="collections-section" id="collections" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-title-wrap text-center">
      <span class="section-subtitle">{{ section.settings.subtitle }}</span>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="collections-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection_item' -%}
          {%- assign collection = collections[block.settings.collection] -%}
          
          <a href="{% if collection != blank %}{{ collection.url }}{% else %}#{% endif %}" class="collection-card" {{ block.shopify_attributes }}>
            <div class="collection-image-wrap">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" 
                     alt="{{ block.settings.title | default: collection.title }}" 
                     class="collection-img">
              {%- elsif collection.image != blank -%}
                <img src="{{ collection.image | image_url: width: 600 }}" 
                     alt="{{ collection.title }}" 
                     class="collection-img">
              {%- else -%}
                <div style="background-color: var(--caramel); opacity: 0.15; height: 350px; width: 100%;"></div>
              {%- endif -%}
            </div>
            <div class="collection-card-details">
              <h3 class="collection-card-title">
                {{ block.settings.title | default: collection.title | default: "Bespoke Collection" }}
              </h3>
              <span class="collection-shop-link">
                Shop Collection
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading Text",
      "default": "Curated Collections"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle Description",
      "default": "Explore the range"
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image Override"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title Override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "category": "Collection",
      "blocks": [
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        }
      ]
    }
  ]
}
{% endschema %}
