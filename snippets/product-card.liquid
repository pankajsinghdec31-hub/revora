{%- comment -%}
  Atelier Reusable Luxury Product Card Snippet
{%- endcomment -%}

{%- assign featured_variant = product.selected_or_first_available_variant -%}

<div class="product-card stagger-item" data-product-id="{{ product.id }}">
  <div class="product-img-wrap">
    {%- if product.compare_at_price > product.price -%}
      <span class="product-badge sale">Sale</span>
    {%- elsif product.tags contains 'Best Seller' or product.tags contains 'best-seller' or forloop.index == 1 or forloop.index == 2 -%}
      <span class="product-badge">Best Seller</span>
    {%- endif -%}
    
    <button class="product-wishlist-btn wishlist-toggle-btn" data-id="{{ product.id }}" aria-label="Add to wishlist">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </button>
    
    <a href="{{ product.url }}">
      <img src="{{ product.featured_image | image_url: width: 600 }}" 
           class="product-img" 
           alt="{{ product.title }}"
           loading="lazy">
    </a>
    
    <!-- Quick View overlay button -->
    <div class="product-quick-view-btn" onclick="window.location.href='{{ product.url }}'">Quick View</div>
  </div>

  <div class="product-info">
    <!-- Color thumbnail swatches (under image) -->
    <div class="product-card-colors">
      {%- for option in product.options_with_values -%}
        {%- if option.name == 'Color' or option.name == 'Colour' -%}
          {%- for value in option.values -%}
            {%- assign variant_for_value = product.variants | where: 'option1', value | first -%}
            {%- if variant_for_value == blank -%}
              {%- assign variant_for_value = product.variants | where: 'option2', value | first -%}
            {%- endif -%}
            {%- if variant_for_value == blank -%}
              {%- assign variant_for_value = product.variants | where: 'option3', value | first -%}
            {%- endif -%}
            <span class="product-swatch {% if forloop.first %}active{% endif %}" 
                  data-color="{{ value }}" 
                  data-index="{{ forloop.index0 }}"
                  {% if variant_for_value.image %}
                    style="background-image: url('{{ variant_for_value.image | image_url: width: 50 }}');"
                  {% else %}
                    style="background-color: {{ value | downcase }};"
                  {% endif %}
                  title="{{ value }}"></span>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="product-card-details">
      <h3 class="product-card-title">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>
      <p class="product-card-benefit">
        {{ product.description | strip_html | truncatewords: 6 | default: "Seamless wire-free contour, weightless support" }}
      </p>
      
      <div class="product-rating-price-row">
        <div class="product-rating">
          <div class="rating-stars">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <span class="rating-count">(4.9)</span>
        </div>
        <div class="product-card-price-wrap">
          <span class="product-card-price">{{ featured_variant.price | money }}</span>
          {%- if featured_variant.compare_at_price > featured_variant.price -%}
            <span class="product-card-price-old">{{ featured_variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Sizes selector wrap -->
    <div class="product-sizes-selector-wrap">
      <div class="product-sizes-selector">
        {%- for option in product.options_with_values -%}
          {%- if option.name == 'Size' or option.name == 'Sizes' -%}
            {%- for value in option.values limit: 5 -%}
              <button class="size-select-btn quick-add-size" data-id="{{ product.id }}" data-size="{{ value }}">{{ value }}</button>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>
